{
    "name":  "vectorizer/ai",
    "version":  "1.0.0",
    "description":  "Official PHP SDK for the Vectorizer.AI image vectorization API.",
    "keywords":  [
                     "openapitools",
                     "openapi-generator",
                     "openapi",
                     "php",
                     "sdk",
                     "rest",
                     "api"
                 ],
    "homepage":  "https://github.com/clv/vectorizer-ai-php",
    "license":  "Apache-2.0",
    "authors":  [
                    {
                        "name":  "Vectorizer.AI",
                        "homepage":  "https://vectorizer.ai"
                    }
                ],
    "require":  {
                    "php":  "^7.4 || ^8.0",
                    "ext-curl":  "*",
                    "ext-json":  "*",
                    "ext-mbstring":  "*",
                    "guzzlehttp/guzzle":  "^7.3",
                    "guzzlehttp/psr7":  "^1.7 || ^2.0"
                },
    "require-dev":  {
                        "phpunit/phpunit":  "^8.0 || ^9.0",
                        "friendsofphp/php-cs-fixer":  "^3.5"
                    },
    "autoload":  {
                     "psr-4":  {
                                   "VectorizerAI\\":  "lib/"
                               }
                 },
    "autoload-dev":  {
                         "psr-4":  {
                                       "VectorizerAI\\Test\\":  "test/"
                                   }
                     }
}